{
  "expo": {
    "name": "MODU",
    "slug": "modu",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "modu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF7F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.modu.client",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "음성 입력으로 더 자연스럽게 답하실 수 있어요.",
        "NSCalendarsUsageDescription": "MODU가 시술·진료 일정을 캘린더와 동기화합니다.",
        "NSCameraUsageDescription": "에셋 사진을 촬영합니다. (반려동물 사진, 진료 카드 등)",
        "NSPhotoLibraryUsageDescription": "에셋 사진을 갤러리에서 선택합니다.",
        "NSPhotoLibraryAddUsageDescription": "MODU에서 보정·생성한 사진을 갤러리에 저장합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.modu.client",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDF7F4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "에셋 사진을 갤러리에서 선택합니다.",
          "cameraPermission": "에셋 사진을 촬영합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TBD-set-via-eas-init"
      }
    },
    "owner": "modu"
  }
}
