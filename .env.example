# MODU 환경변수 — 복사하여 .env 로 사용 (gitignore 됨)
# Expo 는 EXPO_PUBLIC_ prefix 가 있어야 client 번들에 노출.

# ─── Supabase (ADR-0001) ───
# Region: ap-northeast-2 (Seoul). Assign at project creation — region is stable.
# Dashboard → New Project → Region: Northeast Asia (Seoul)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=public-anon-key

# NOTE: 서버 전용 시크릿 (SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY, R2_*)은
# supabase/functions/.env.functions.example 를 참고하세요. 절대 이 파일에 두지 마세요.

# ─── 환경 식별자 ───
EXPO_PUBLIC_ENV=development                # development | preview | production

# ─── 개발 옵션 ───
# 1=on, 0/unset=off
EXPO_PUBLIC_SEED_DEMO=0                    # mock 에셋 3개 미리 채울지
EXPO_PUBLIC_DEV_MESSAGES=0                 # 빈 탭에 dev 메시지 vs "곧 만나요" 표시
